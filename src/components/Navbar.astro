---
// src/components/Navbar.astro
---
<nav class="main-nav">
    <div class="nav-container">
        <a href="/" class="logo">MV<span class="blue-text">77</span></a>
        
        <div class="nav-links" id="navLinks">
            <a href="/carriera">History</a>
            <a href="/journal">Journal</a>
            <a href="/media">Media</a>
            <a href="/contact">Contact</a>
        </div>

        <button class="menu-btn" id="menuBtn" aria-label="Toggle Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</nav>

<style>
    .main-nav {
        position: fixed; top: 0; left: 0; width: 100%;
        background: rgba(5, 5, 5, 0.95);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px); /* Supporto per Safari iOS */
        z-index: 9999;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .nav-container {
        max-width: 1300px; margin: 0 auto; padding: 15px 30px;
        display: flex; justify-content: space-between; align-items: center;
    }
    .logo {
        font-family: 'Syncopate', sans-serif; font-weight: 700; color: white;
        text-decoration: none; font-size: 1.3rem; letter-spacing: -1px;
    }
    .blue-text { color: #00b4ff; }
    .nav-links { display: flex; gap: 30px; }
    .nav-links a {
        color: rgba(255, 255, 255, 0.7); text-decoration: none;
        text-transform: uppercase; font-size: 0.75rem; font-weight: 700;
        letter-spacing: 2px; transition: 0.3s;
    }
    .nav-links a:hover { color: #00b4ff; }

    /* Pulsante Hamburger con transizioni per l'animazione a X */
    .menu-btn { 
        display: none; 
        flex-direction: column; 
        gap: 6px; 
        background: none; 
        border: none; 
        cursor: pointer; 
        padding: 4px;
        z-index: 10000; /* Sta sopra al menu a tendina */
    }
    .menu-btn span { 
        width: 24px; 
        height: 2px; 
        background: white; 
        transition: transform 0.3s ease, opacity 0.3s ease;
        transform-origin: center;
    }

    /* ==========================================================================
       TELEMETRIA MOBILE
       ========================================================================== */
    @media (max-width: 768px) {
        .nav-container {
            padding: 15px 20px; /* Più spazio laterale su mobile */
        }

        .menu-btn { 
            display: flex; 
        }

        /* Animazione da Hamburger a X */
        .menu-btn.active span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
            background: #00b4ff; /* Diventa blu quando è aperto */
        }
        .menu-btn.active span:nth-child(2) {
            opacity: 0; /* La linea in mezzo sparisce */
        }
        .menu-btn.active span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
            background: #00b4ff;
        }

        .nav-links {
            position: fixed; 
            top: 0; 
            right: -100%; 
            width: 100%; 
            height: 100vh;
            background: #050505; 
            flex-direction: column; 
            justify-content: center;
            align-items: center; 
            gap: 40px; /* Più respiro tra i link nel menu a tutto schermo */
            transition: right 0.4s cubic-bezier(0.77, 0, 0.175, 1); /* Transizione più fluida ed elegante */
        }
        
        .nav-links.active { 
            right: 0; 
        }
        
        .nav-links a { 
            font-size: 1.3rem; /* Dimensione aumentata ma bilanciata per smartphone */
            letter-spacing: 4px;
        }
    }
</style>

<script>
    const btn = document.getElementById('menuBtn');
    const links = document.getElementById('navLinks');
    
    // Al click, aggiungiamo/togliamo la classe 'active' sia ai link che al pulsante stesso
    btn?.addEventListener('click', () => {
        btn.classList.toggle('active');
        links?.classList.toggle('active');
    });

    // Opzionale: Chiude il menu se l'utente clicca su un link
    const navItems = links?.querySelectorAll('a');
    navItems?.forEach(item => {
        item.addEventListener('click', () => {
            btn?.classList.remove('active');
            links?.classList.remove('active');
        });
    });
</script>