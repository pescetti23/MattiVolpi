---
// src/components/Footer.astro
---
<footer class="racing-footer">
    <div class="footer-container">
        <div class="footer-main">
            <div class="footer-brand">
                <a href="/" class="footer-logo">VOLPI<span class="blue-text">77</span></a>
                <p>Pushing the limits of speed and technology.</p>
            </div>
            
            <div class="social-links">
                <a href="https://www.instagram.com/" target="_blank" aria-label="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="https://www.tiktok.com/" target="_blank" aria-label="TikTok">
                    <i class="fab fa-tiktok"></i>
                </a>
                <a href="https://www.youtube.com/" target="_blank" aria-label="YouTube">
                    <i class="fab fa-youtube"></i>
                </a>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>© 2026 MATTIA VOLPI #77 // ALL RIGHTS RESERVED</p>
        </div>
    </div>
</footer>

<style>
    .racing-footer {
        background: #000;
        padding: 60px 0 30px 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        margin-top: 80px;
        width: 100%;
        color: white;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 30px;
        box-sizing: border-box;
    }

    .footer-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 40px;
    }

    .footer-logo {
        font-family: 'Syncopate', sans-serif;
        font-weight: 700;
        color: white;
        text-decoration: none;
        font-size: 1.4rem;
        letter-spacing: -1px;
    }

    .blue-text { color: #00b4ff; }

    .footer-brand p {
        opacity: 0.4;
        font-size: 0.75rem;
        margin: 8px 0 0 0;
        letter-spacing: 1px;
    }

    .social-links {
        display: flex;
        gap: 20px;
    }

    .social-links a {
        color: white;
        font-size: 1.4rem;
        transition: 0.3s ease;
        opacity: 0.5;
    }

    .social-links a:hover {
        color: #00b4ff;
        opacity: 1;
        transform: translateY(-3px);
    }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-top: 30px;
        text-align: center;
    }

    .footer-bottom p {
        font-family: 'Syncopate', sans-serif;
        font-size: 0.5rem;
        letter-spacing: 3px;
        opacity: 0.2;
        margin: 0;
    }

    /* ==========================================================================
       TELEMETRIA MOBILE (Sotto i 768px di larghezza schermo)
       ========================================================================== */
    @media (max-width: 768px) {
        .racing-footer {
            padding: 40px 0 20px 0; /* Ridotto il padding verticale per non creare vuoti giganti */
            margin-top: 40px;       /* Meno distacco dal contenuto sui telefoni */
        }

        .footer-container {
            padding: 0 20px;        /* Margini interni laterali più stretti per sfruttare lo schermo */
        }

        .footer-main {
            flex-direction: column;
            gap: 25px;              /* Gestione millimetrica dello spazio verticale tra brand e icone */
            text-align: center;
            padding-bottom: 30px;
        }

        .footer-brand p {
            font-size: 0.7rem;      /* Ridotto un filo il testo descrittivo per farlo stare su una riga sola */
            max-width: 280px;       /* Evita che il testo si spalmi troppo vicino ai bordi */
            margin: 8px auto 0 auto; /* Centra il blocco di testo nel layout a colonna */
        }

        .social-links {
            justify-content: center;
            gap: 25px;              /* Distanziate leggermente di più le icone per facilitare il "tap" con il dito */
        }
        
        .footer-bottom {
            padding-top: 20px;
        }
        
        .footer-bottom p {
            font-size: 0.45rem;     /* Riduzione di sicurezza per evitare che la riga del copyright vada a capo rompendo il design */
            line-height: 1.4;
        }
    }
</style>