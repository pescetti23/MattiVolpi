---
import Navbar from '../components/Navbar.astro';
---

<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CONTACT // MATTIA VOLPI #77</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Inter:wght@300;400;900&display=swap" rel="stylesheet">
    
    <style>
        :root { --blue: #00b4ff; --black: #050505; --dark-gray: #0d0d0d; }
        body { 
            margin: 0; background: var(--black); color: white; 
            font-family: 'Inter', sans-serif; overflow-x: hidden;
            /* Griglia tecnica e sfumatura coordinate con il resto del sito */
            background-image: 
                radial-gradient(circle at 50% 0%, rgba(0, 180, 255, 0.1) 0%, transparent 50%),
                linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
            background-size: 100% 100%, 60px 60px, 60px 60px;
            background-attachment: fixed;
        }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

        .contact-header { padding: 200px 0 60px; text-align: center; }
        .tag { font-family: 'Syncopate'; color: var(--blue); font-size: 0.6rem; letter-spacing: 5px; text-transform: uppercase; }
        h1 { font-family: 'Syncopate'; font-size: clamp(2.5rem, 8vw, 4.5rem); font-style: italic; margin: 15px 0; text-transform: uppercase; letter-spacing: -1px; }

        .contact-grid { 
            display: grid; 
            grid-template-columns: 1fr 1.5fr; 
            gap: 80px; 
            padding: 40px 0 120px;
        }

        /* --- INFO LATERALE STILE HUD --- */
        .info-card { 
            background: rgba(13, 13, 13, 0.7); 
            padding: 40px; 
            border: 1px solid rgba(0, 180, 255, 0.1);
            border-left: 3px solid var(--blue); 
            backdrop-filter: blur(15px);
            position: relative;
        }
        /* Angolino tecnico in alto a destra */
        .info-card::after {
            content: ''; position: absolute; top: 0; right: 0; width: 15px; height: 15px;
            border-top: 2px solid var(--blue); border-right: 2px solid var(--blue);
            opacity: 0.4;
        }
        .info-section { margin-bottom: 40px; }
        .info-section:last-child { margin-bottom: 0; }
        .info-section h3 { font-family: 'Syncopate'; font-size: 0.7rem; color: var(--blue); letter-spacing: 2px; margin-bottom: 15px; }
        .info-section p { font-size: 1.1rem; opacity: 0.8; font-weight: 300; margin: 5px 0; }
        
        .social-list { display: flex; gap: 25px; margin-top: 20px; }
        .social-list a { color: white; font-size: 1.3rem; transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1); opacity: 0.5; }
        .social-list a:hover { color: var(--blue); opacity: 1; transform: translateY(-4px) scale(1.1); }

        /* --- FORM CON COORD. DESIGN --- */
        .contact-form { display: grid; gap: 25px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; position: relative; }
        .form-group label { font-family: 'Syncopate'; font-size: 0.55rem; letter-spacing: 2px; opacity: 0.6; color: #fff; }
        
        input, textarea {
            background: rgba(13, 13, 13, 0.6);
            border: 1px solid rgba(0, 180, 255, 0.15);
            padding: 18px;
            color: white;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            box-sizing: border-box;
        }

        input::placeholder, textarea::placeholder {
            color: rgba(255, 255, 255, 0.25);
            font-size: 0.85rem;
        }

        input:focus, textarea:focus {
            outline: none;
            border-color: var(--blue);
            background: rgba(0, 180, 255, 0.04);
            box-shadow: 0 0 15px rgba(0, 180, 255, 0.1);
        }

        /* --- TASTO FINALE TELEMETRIA --- */
        .btn-send {
            background: transparent;
            border: 1px solid var(--blue);
            color: var(--blue);
            padding: 22px;
            font-family: 'Syncopate';
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 4px;
            cursor: pointer;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            text-transform: uppercase;
            width: 100%;
            margin-top: 10px;
            outline: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .btn-send i {
            font-size: 0.8rem;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .btn-send:hover {
            background: var(--blue);
            color: var(--black);
            box-shadow: 0 0 30px rgba(0, 180, 255, 0.4);
            transform: translateY(-2px);
        }

        .btn-send:hover i {
            transform: translateX(5px);
        }

        .btn-send:active {
            transform: scale(0.98);
        }

        @media (max-width: 850px) {
            .contact-grid { grid-template-columns: 1fr; gap: 40px; padding-bottom: 80px; }
            .contact-header { padding-top: 140px; padding-bottom: 30px; }
            .info-card { padding: 30px; }
            input, textarea { padding: 15px; }
        }
    </style>
</head>
<body>

    <Navbar />

    <div class="container">
        <header class="contact-header">
            <span class="tag">COMMUNICATION PORT // OPEN</span>
            <h1>CONTACT <span style="color:var(--blue)">CENTER</span></h1>
        </header>

        <main class="contact-grid">
            <aside>
                <div class="info-card">
                    <div class="info-section">
                        <h3>MANAGEMENT</h3>
                        <p style="font-weight: 400; color: var(--blue);">info@mattiavolpi.it</p>
                    </div>

                    <div class="info-section">
                        <h3>RACING ID</h3>
                        <p style="font-weight: 900; letter-spacing: -0.5px;">Mattia Volpi #77</p>
                        <p style="opacity: 0.6; font-size: 0.95rem;">CIV Superbike // BMW M1000RR</p>
                    </div>

                    <div class="info-section">
                        <h3>SOCIAL CHANNELS</h3>
                        <div class="social-list">
                            <a href="#" target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                            <a href="#" target="_blank" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
                            <a href="#" target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </aside>

            <section>
                <form class="contact-form" method="POST">
                    <div class="form-group">
                        <label>FULL NAME</label>
                        <input type="text" name="name" placeholder="E.g. John Doe" required />
                    </div>
                    
                    <div class="form-group">
                        <label>EMAIL ADDRESS</label>
                        <input type="email" name="email" placeholder="name@example.com" required />
                    </div>

                    <div class="form-group">
                        <label>SUBJECT</label>
                        <input type="text" name="subject" placeholder="Sponsorship / Press / Inquiry" />
                    </div>

                    <div class="form-group">
                        <label>MESSAGE</label>
                        <textarea name="message" rows="6" placeholder="Type your data payload transmission here..." required></textarea>
                    </div>

                    <button type="submit" class="btn-send">
                        <span>TRANSMIT DATA</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </form>
            </section>
        </main>
    </div>

    <footer style="padding: 60px 0; text-align: center; border-top: 1px solid rgba(0, 180, 255, 0.1); background: rgba(0,0,0,0.3);">
        <p style="font-family:'Syncopate'; font-size:0.55rem; opacity:0.3; letter-spacing: 3px;">
            © 2026 MATTIA VOLPI #77 // COMMUNICATION TERMINAL
        </p>
    </footer>

</body>
</html>