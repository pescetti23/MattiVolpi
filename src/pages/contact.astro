---
import Navbar from '../components/Navbar.astro';
---

<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CONTACT // MATTIA VOLPI #77</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Inter:wght@300;400;900&display=swap" rel="stylesheet">
    
    <style>
        :root { --blue: #00b4ff; --black: #050505; }
        body { 
            margin: 0; background: var(--black); color: white; 
            font-family: 'Inter', sans-serif;
            background-image: radial-gradient(circle at 50% 0%, rgba(0, 180, 255, 0.05) 0%, transparent 50%);
        }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

        .contact-header { padding: 180px 0 60px; text-align: center; }
        .tag { font-family: 'Syncopate'; color: var(--blue); font-size: 0.6rem; letter-spacing: 5px; text-transform: uppercase; }
        h1 { font-family: 'Syncopate'; font-size: clamp(2.5rem, 8vw, 4.5rem); font-style: italic; margin: 15px 0; text-transform: uppercase; }

        .contact-grid { 
            display: grid; 
            grid-template-columns: 1fr 1.5fr; 
            gap: 80px; 
            padding: 60px 0 120px;
        }

        /* --- INFO LATERALE --- */
        .info-card { background: rgba(255,255,255,0.02); padding: 40px; border-left: 2px solid var(--blue); }
        .info-section { margin-bottom: 40px; }
        .info-section h3 { font-family: 'Syncopate'; font-size: 0.7rem; color: var(--blue); letter-spacing: 2px; margin-bottom: 15px; }
        .info-section p { font-size: 1.1rem; opacity: 0.8; font-weight: 300; margin: 5px 0; }
        
        .social-list { display: flex; gap: 20px; margin-top: 20px; }
        .social-list a { color: white; font-size: 1.2rem; transition: 0.3s; opacity: 0.5; }
        .social-list a:hover { color: var(--blue); opacity: 1; transform: translateY(-3px); }

        /* --- FORM --- */
        .contact-form { display: grid; gap: 25px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; }
        .form-group label { font-family: 'Syncopate'; font-size: 0.5rem; letter-spacing: 2px; opacity: 0.6; }
        
        input, textarea {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 15px;
            color: white;
            font-family: 'Inter', sans-serif;
            transition: 0.3s;
        }

        input:focus, textarea:focus {
            outline: none;
            border-color: var(--blue);
            background: rgba(0, 180, 255, 0.05);
        }

        /* FIX TASTO FINALE */
        .btn-send {
            background: transparent;
            border: 1px solid var(--blue);
            color: var(--blue); /* Testo blu inizialmente */
            padding: 22px;
            font-family: 'Syncopate';
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 4px;
            cursor: pointer;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            text-transform: uppercase;
            width: 100%;
            margin-top: 10px;
            outline: none;
        }

        .btn-send:hover {
            background: var(--blue);
            color: var(--black); /* Testo nero su sfondo blu */
            box-shadow: 0 0 25px rgba(0, 180, 255, 0.5);
            transform: translateY(-2px);
        }

        .btn-send:active {
            transform: scale(0.98);
        }

        @media (max-width: 850px) {
            .contact-grid { grid-template-columns: 1fr; gap: 50px; }
            .contact-header { padding-top: 120px; }
        }
    </style>
</head>
<body>

    <Navbar />

    <div class="container">
        <header class="contact-header">
            <span class="tag">Get in touch</span>
            <h1>CONTACT <span style="color:var(--blue)">CENTER</span></h1>
        </header>

        <main class="contact-grid">
            <aside>
                <div class="info-card">
                    <div class="info-section">
                        <h3>MANAGEMENT</h3>
                        <p>info@mattiavolpi.it</p>
                    </div>

                    <div class="info-section">
                        <h3>RACING ID</h3>
                        <p>Mattia Volpi #77</p>
                        <p>CIV Superbike / Supersport</p>
                    </div>

                    <div class="info-section">
                        <h3>SOCIAL CHANNELS</h3>
                        <div class="social-list">
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </aside>

            <section>
                <form class="contact-form" method="POST">
                    <div class="form-group">
                        <label>FULL NAME</label>
                        <input type="text" name="name" placeholder="Your name" required />
                    </div>
                    
                    <div class="form-group">
                        <label>EMAIL ADDRESS</label>
                        <input type="email" name="email" placeholder="email@example.com" required />
                    </div>

                    <div class="form-group">
                        <label>SUBJECT</label>
                        <input type="text" name="subject" placeholder="Sponsorship / Press / Fan" />
                    </div>

                    <div class="form-group">
                        <label>MESSAGE</label>
                        <textarea name="message" rows="6" placeholder="Write your message here..." required></textarea>
                    </div>

                    <button type="submit" class="btn-send">SEND MESSAGE</button>
                </form>
            </section>
        </main>
    </div>

    <footer style="padding: 60px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.05);">
        <p style="font-family:'Syncopate'; font-size:0.5rem; opacity:0.2; letter-spacing: 3px;">
            © 2026 MATTIA VOLPI #77 // COMMUNICATION TERMINAL
        </p>
    </footer>

</body>
</html>