---
import Navbar from '../components/Navbar.astro';

// 1. Carichiamo i file dal percorso corretto (assicurati che i file siano in src/pages/blog/)
const allPosts = await import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.values(allPosts);

// 2. Mappiamo i post per assicurarci di passare solo i dati validi
const sortedPosts = posts.map(post => ({
    url: post.url,
    title: post.frontmatter.title || "Senza Titolo",
    date: post.frontmatter.date || "Data non definita",
    category: post.frontmatter.category || "NEWS",
    description: post.frontmatter.description || "Nessuna descrizione disponibile."
}));
---

<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JOURNAL // MATTIA VOLPI #77</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Inter:wght@300;400;900&display=swap" rel="stylesheet">
    
    <style>
        :root { --blue: #00b4ff; --black: #050505; --dark-gray: #0d0d0d; }
        
        body { 
            margin: 0; background: var(--black); color: white; 
            font-family: 'Inter', sans-serif; overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 50% 0%, rgba(0, 180, 255, 0.1) 0%, transparent 50%),
                linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
            background-size: 100% 100%, 60px 60px, 60px 60px;
            background-attachment: fixed;
        }
        
        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
        .journal-header { padding: 200px 0 60px; text-align: left; border-bottom: 1px solid rgba(0, 180, 255, 0.1); }
        .tag { font-family: 'Syncopate'; color: var(--blue); font-size: 0.6rem; letter-spacing: 5px; text-transform: uppercase; }
        h1 { font-family: 'Syncopate'; font-size: clamp(2.5rem, 8vw, 4.5rem); font-style: italic; margin: 15px 0; text-transform: uppercase; letter-spacing: -1px; }
        .journal-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; padding: 60px 0 120px; }

        .log-card {
            background: rgba(13, 13, 13, 0.7);
            border: 1px solid rgba(0, 180, 255, 0.1);
            padding: 35px;
            position: relative;
            backdrop-filter: blur(15px);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            text-decoration: none;
            color: white;
        }

        .log-card::after {
            content: ''; position: absolute; top: 0; right: 0; width: 20px; height: 20px;
            border-top: 2px solid var(--blue); border-right: 2px solid var(--blue);
            opacity: 0.3; transition: 0.4s ease;
        }

        .log-card:hover {
            border-color: var(--blue);
            background: rgba(0, 180, 255, 0.02);
            box-shadow: 0 15px 30px rgba(0, 180, 255, 0.05);
            transform: translateY(-4px);
        }

        .log-card:hover::after { opacity: 1; width: 30px; height: 30px; }

        .log-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
        .log-id { font-family: 'Syncopate'; font-size: 0.6rem; color: var(--blue); letter-spacing: 2px; }
        .log-date { font-size: 0.85rem; opacity: 0.4; font-weight: 300; }
        .log-card h2 { font-family: 'Syncopate'; font-size: 1.25rem; line-height: 1.4; margin: 0 0 15px 0; text-transform: uppercase; transition: 0.3s; }
        .log-card:hover h2 { color: var(--blue); }
        .log-card p { font-size: 0.95rem; opacity: 0.6; line-height: 1.7; font-weight: 300; margin: 0 0 30px 0; flex-grow: 1; }
        .log-link { font-family: 'Syncopate'; font-size: 0.65rem; letter-spacing: 2px; display: inline-flex; align-items: center; gap: 10px; color: var(--blue); text-transform: uppercase; }
        
        @media (max-width: 850px) {
            .journal-grid { grid-template-columns: 1fr; gap: 30px; padding-bottom: 80px; }
            .journal-header { padding-top: 140px; padding-bottom: 40px; }
        }
    </style>
</head>
<body>

    <Navbar />

    <div class="container">
        <header class="journal-header">
            <span class="tag">Telemetry & Stories</span>
            <h1>PILOT <span style="color:var(--blue)">JOURNAL</span></h1>
        </header>

        <main class="journal-grid">
            {sortedPosts.map((post) => (
                <a href={post.url} class="log-card">
                    <div>
                        <div class="log-meta">
                            <span class="log-id">LOG // {post.category}</span>
                            <span class="log-date">{post.date}</span>
                        </div>
                        <h2>{post.title}</h2>
                        <p>{post.description}</p>
                    </div>
                    <span class="log-link">READ DATA PAYLOAD <i class="fas fa-chevron-right"></i></span>
                </a>
            ))}
        </main>
    </div>

    <footer style="padding: 60px 0; text-align: center; border-top: 1px solid rgba(0, 180, 255, 0.1); background: rgba(0,0,0,0.3);">
        <p style="font-family:'Syncopate'; font-size:0.55rem; opacity:0.3; letter-spacing: 3px;">
            © 2026 MATTIA VOLPI #77 // DATA LOG TERMINAL
        </p>
    </footer>
</body>
</html>